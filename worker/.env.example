# Copy to .env and fill in real values to run dev:node against Salesforce
# instead of the in-memory mock. Leave .env absent/empty to stay on mock.

# Connected App consumer key/secret, configured for the OAuth 2.0 Client
# Credentials Flow. Required to enable SalesforceStore.
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# Optional. Only needed if your org uses a My Domain login URL instead of
# https://login.salesforce.com (most production orgs do).
SF_LOGIN_URL=

# Optional. Frontend origin that magic links point at. Defaults to
# http://localhost:3000 (the Vite dev server) if unset.
APP_URL=

# Placeholder Opportunity Ids the composer's special picks attach to.
# Both should be real Opportunities with a Project_Status__c OUTSIDE
# CFG.opp.openStatuses in salesforce.ts, so they never show up as a
# selectable job themselves.
NEW_WO_OPPORTUNITY_ID=
TIME_OFF_OPPORTUNITY_ID=

# Secret used to sign magic links and device tokens (see src/auth.ts). Not
# Salesforce-related -- any long random string works, e.g. `openssl rand
# -hex 32`. If unset, dev-node falls back to an insecure hardcoded dev
# secret (with a console warning). Deployed workers must set a real one via
# `wrangler secret put AUTH_SECRET` -- don't reuse this local value there.
AUTH_SECRET=

